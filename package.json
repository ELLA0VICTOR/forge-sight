{
    "name":  "foresight",
    "version":  "1.0.0",
    "private":  true,
    "type":  "module",
    "packageManager":  "pnpm@9.15.9",
    "scripts":  {
                    "dev":  "corepack pnpm --filter @foresight/dashboard dev",
                    "build":  "corepack pnpm -r build",
                    "test":  "corepack pnpm --filter @foresight/engine test",
                    "gen:fixtures":  "corepack pnpm --filter @foresight/fixtures-cli gen",
                    "server":  "corepack pnpm --filter @foresight/server dev",
                    "mcp":  "corepack pnpm --filter @foresight/mcp dev",
                    "cli":  "corepack pnpm --filter @foresight/cli dev"
                },
    "devDependencies":  {
                            "@types/node":  "^20.14.15",
                            "tsx":  "^4.19.2",
                            "typescript":  "^5.6.3",
                            "vitest":  "^2.1.8"
                        }
}